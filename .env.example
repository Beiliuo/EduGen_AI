# Copy this file to .env.local and fill in your own API key.
# OPENAI_API_KEY is required for question generation.

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL=gpt-4o-mini

# Xiaomi MiMo OpenAI-compatible example:
# OPENAI_BASE_URL=https://token-plan-cn.xiaomimimo.com/v1
# AI_MODEL=mimo-v2.5-pro
